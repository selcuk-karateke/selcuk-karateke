{
  "name": "portfolio-selcuk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "node scripts/clean-next-cache.mjs && next dev",
    "dev:fresh": "node scripts/kill-port.mjs 3000 && node scripts/clean-next-cache.mjs && next dev",
    "clean:next": "node scripts/clean-next-cache.mjs",
    "postinstall": "prisma generate",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "legacy:extract": "tsx scripts/extract-legacy-content.ts",
    "legacy:assets": "tsx scripts/sync-legacy-assets.ts",
    "legacy:sync": "npm run legacy:extract && npm run legacy:assets",
    "education:import": "tsx scripts/import-education-floors.ts",
    "exercises:import": "tsx scripts/import-exercises.ts",
    "content:import": "npm run legacy:extract && npm run education:import && npm run exercises:import"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.16.3",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "next-auth": "^4.24.11",
    "next-intl": "^4.12.0",
    "prisma": "^6.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
